# Local dev — Vite proxies /api/* → http://localhost:3000 (see vite.config.ts).
# Leave VITE_API_URL unset so authClient uses relative URLs, keeping everything
# same-origin and avoiding cross-port cookie issues with Google OAuth.
#
# In production (Vercel), set VITE_API_URL=https://lms-services.ggecl.com
# in the Vercel dashboard (Settings → Environment Variables).
# VITE_API_URL=http://localhost:3000
