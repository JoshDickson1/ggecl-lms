# All HTTP/REST API calls use relative /api/* URLs in both dev and production.
# Dev:  Vite proxy (vite.config.ts) rewrites /api/* → VITE_PROXY_TARGET (default: http://127.0.0.1:3000)
# Prod: Vercel rewrite (vercel.json) proxies /api/* → https://lms-services.ggecl.com
# No VITE_API_URL needed — keeping everything same-origin prevents
# third-party cookie blocking in Safari / Firefox strict mode.

# Override in .env.local to point at a different backend (e.g. production backend for dev testing).
# VITE_PROXY_TARGET=http://127.0.0.1:3000

# Socket.IO cannot go through the Vercel proxy (no WebSocket support).
# It connects directly to the backend. Set this in Vercel env vars too.
VITE_SOCKET_URL=https://lms-services.ggecl.com
